rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /enquiries/{enquiryId} {
      allow create: if request.resource.data.fullName is string &&
                      request.resource.data.phone is string &&
                      request.resource.data.email is string &&
                      request.resource.data.services is list &&
                      request.resource.data.createdAt == request.time &&
                      request.resource.data.status == 'new';
      allow read, update, delete: if request.auth != null && request.auth.token.email == "docestatesolutions@gmail.com";
    }
    
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.token.email == "docestatesolutions@gmail.com";
    }
  }
}
